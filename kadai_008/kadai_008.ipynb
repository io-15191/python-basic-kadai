      "source": [
        "#ランダムな整数をりようするために、randomモジュールをインポート\n",
        "import random\n",
        "\n",
        "#変数varにランダムな整数を代入\n",
        "var = random.randint(0 , 100)\n",
        "\n",
        "#変数varの値が3の倍数であれば「Fizz」という文字列を出力する\n",
        "if var % 3 == 0 and var % 5 == 0:\n",
        "  print(\"FizzBuzz\")\n",
        "elif var % 5 == 0:\n",
        "  print(\"Buzz\")\n",
        "elif var % 3 == 0:\n",
        "  print(\"Fizz\")\n",
        "else:\n",
        "  print(var)\n"
      ]
    }
  ]
}